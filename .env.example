# Bot Configuration
BOT_TOKEN=your_bot_token_here
BOT_USERNAME=KefPulse_bot
CHANNEL_ID=@kefpulsechannel
ADMIN_IDS=123456789,987654321

# Yandex API
YANDEX_API_KEY=your_yandex_api_key
YANDEX_TRAFFIC_API_KEY=your_traffic_key
YANDEX_BEARER_TOKEN=your_bearer_token
YANDEX_UUID=your_uuid
YANDEX_DEVICE_ID=your_device_id
YANDEX_MOB_ID=your_mob_id
YANDEX_GEOCODER_KEY=your_geocoder_key

# TomTom API
TOMTOM_API_KEY=your_tomtom_key

# Google Gemini API (AI Advisor)
GEMINI_API_KEY=your_gemini_key

# Payment Provider Selection
PAYMENT_PROVIDER=robokassa

# YooKassa (if using)
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_secret_key

# Robokassa (if using)
ROBOKASSA_MERCHANT_LOGIN=your_merchant_login
ROBOKASSA_PASSWORD1=your_password1
ROBOKASSA_PASSWORD2=your_password2
ROBOKASSA_TEST_MODE=True

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost/dbname

# Redis
REDIS_URL=redis://localhost:6379/0

# Web Server
WEBAPP_URL=https://your-domain.com
WEB_HOST=0.0.0.0
WEB_PORT=8080

# Admin Panel
ADMIN_PASSWORD=your_secure_password

# Environment
ENVIRONMENT=production
PARSE_INTERVAL_SECONDS=1200
DEFAULT_SURGE_THRESHOLD=1.5
